theme = Catppuccin Mocha
font-family = Google Sans Code NF
font-size = 14
command = /home/marvin/.cargo/bin/nu
shell-integration = detect
window-padding-x = 8
window-padding-y = 8
macos-titlebar-style = tabs
background-opacity = 0.95

custom-shader = shaders/cursor_warp.glsl
custom-shader = shaders/ripple_cursor.glsl
custom-shader-animation = always

# Split / pane management (cmd+alt prefix)
keybind = super+alt+h=goto_split:left
keybind = super+alt+j=goto_split:down
keybind = super+alt+k=goto_split:up
keybind = super+alt+l=goto_split:right
keybind = super+alt+bracket_left=goto_split:previous
keybind = super+alt+bracket_right=goto_split:next
keybind = super+alt+backslash=new_split:right
keybind = super+alt+minus=new_split:down
keybind = super+alt+enter=toggle_split_zoom
keybind = super+alt+w=close_surface
keybind = super+alt+equal=equalize_splits
