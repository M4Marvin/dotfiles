[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    syntax-theme = "Catppuccin Mocha"
    dark = true
    line-numbers = true
    side-by-side = true
    minus-style = syntax "#301030"
    plus-style = syntax "#003020"

[merge]
    conflictStyle = zdiff3
